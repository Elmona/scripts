{
  "html.format.wrapLineLength": 160,
  "html.format.unformatted": "ix:nonFraction,ix:nonNumeric",
  "git.openDiffOnClick": false,
  "keyboard.dispatch": "keyCode",
  "editor.lineNumbers": "on",
  "github.copilot.editor.enableCodeActions": false,
  "sonarlint.connectedMode.project": {
    "connectionId": "agoy",
    "projectKey": "AgoyIt_agoy-monorepo",
  },
  "vim.easymotion": true,
  "vim.statusBarColorControl": true,
  "vim.easymotionKeys": "hklyuiopnmqwertzxcvbasdgjf",
  "vim.leader": "<space>",
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"],
    },
    // {
    //     "before": [
    //         "<leader>",
    //         "d"
    //     ],
    //     "commands": [
    //         "editor.action.triggerSuggest"
    //     ]
    // }
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "a"],
      "commands": ["vscode-harpoon.addEditor"],
    },
    // {
    //   "before": ["<leader>", "a"],
    //   "after": ["<leader>", "<leader>", "s"]
    // },
    {
      "before": ["<leader>", "d"],
      "commands": ["editor.action.triggerSuggest"],
    },
    {
      "before": ["<leader>", "R"],
      "commands": ["editor.action.changeAll"],
    },
    {
      "before": ["<leader>", "s"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["<leader>", "w"],
      "after": ["<C-w>"],
    },
    {
      "before": ["<leader>", "r"],
      "commands": ["workbench.action.debug.start"],
    },
    {
      "before": ["<leader>", "t"],
      "commands": ["workbench.action.tasks.runTask"],
    },
    {
      "before": ["<leader>", "e"],
      "after": ["<leader>", "<leader>", "s"],
    },
    {
      "before": ["f"],
      "after": ["<leader>", "<leader>", "s"],
    },
  ],
